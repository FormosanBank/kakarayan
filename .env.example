# Copy to .env and adjust. Never commit .env.

# --- Database ---
# Canonical/CI/prod target is PostgreSQL 16 (see docker-compose.yml).
# For local dev without Docker, point this at any running Postgres 16/17.
DATABASE_URL=postgres://kakarayan:kakarayan@localhost:5432/kakarayan

# --- Django ---
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- FormosanBank corpus source (read-only) ---
# Path to a local FormosanBank checkout. The ingestion command imports its QC
# parsers and reads the canonical XML under $FORMOSANBANK_REPO/Corpora.
FORMOSANBANK_REPO=/Users/gabrielgras/Documents/FormosanBank
# Optional override; defaults to $FORMOSANBANK_REPO/Corpora
# CORPORA_PATH=/Users/gabrielgras/Documents/FormosanBank/Corpora

# Optional bulk-insert batch size
# INGEST_BATCH_SIZE=2000
